<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= it.title ? `${it.title} — ` : '' %>{{APP_DISPLAY_NAME}}</title>
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="stylesheet" href="/styles.css" />
  <script src="/vendor/htmx.min.js" defer></script>
  <script type="module" src="/assets/app.js"></script>
</head>
<body>
  <% if (it.user) { %>
  <header class="topbar">
    <a class="topbar-brand" href="/">
      <img src="/gz-logo-white.png" alt="" height="20" />
      <span>{{APP_DISPLAY_NAME}}</span>
      <% if (it.stage !== 'prod') { %><span class="badge badge-stage"><%= it.stage %></span><% } %>
    </a>
    <nav class="topbar-nav">
      <a href="/">Dashboard</a>
      <% if (it.user.permissions.includes('users:read')) { %><a href="/users">Users</a><% } %>
    </nav>
    <div class="topbar-user">
      <span class="topbar-email"><%= it.user.email %></span>
      <form method="post" action="/auth/logout"><button class="btn btn-ghost" type="submit">Sign out</button></form>
    </div>
  </header>
  <% } %>
  <main class="page">
    <%~ it.body %>
  </main>
</body>
</html>
