{
  "name": "gzweb-app-template",
  "private": true,
  "type": "module",
  "description": "{{APP_DISPLAY_NAME}} — internal webapp on the unified template (Fastify + Eta + HTMX + Lit, Aurora DSQL, Lambda Web Adapter)",
  "scripts": {
    "predev": "pnpm build:client",
    "dev": "tsx watch src/server.ts",
    "build": "pnpm build:server && pnpm build:client",
    "build:server": "tsc -p tsconfig.build.json",
    "build:client": "esbuild client/index.ts --bundle --format=esm --minify --sourcemap --outfile=public/assets/app.js && mkdir -p public/vendor && cp node_modules/htmx.org/dist/htmx.min.js public/vendor/htmx.min.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "synth": "cdk synth",
    "diff": "cdk diff"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.750.0",
    "@aws-sdk/dsql-signer": "^3.750.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/view": "^10.0.2",
    "drizzle-orm": "^0.41.0",
    "eta": "^3.5.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "htmx.org": "^2.0.4",
    "lit": "^3.2.1",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/pg": "^8.11.11",
    "aws-cdk": "^2.1000.2",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "drizzle-kit": "^0.30.5",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
