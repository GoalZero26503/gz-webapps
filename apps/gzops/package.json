{
  "name": "gzops",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GZOps — internal release-ops portal on the unified template (Fastify + Eta + HTMX + Lit, BFF over the gzops-platform API, app state in DynamoDB, Lambda Web Adapter)",
  "scripts": {
    "predev": "pnpm build:client",
    "dev": "tsx watch src/server.ts",
    "build": "pnpm build:server && pnpm build:client",
    "build:server": "tsc -p tsconfig.build.json",
    "build:client": "esbuild client/index.ts --bundle --format=esm --minify --sourcemap --tsconfig=tsconfig.client.json --target=es2022 --outfile=public/assets/app.js && node scripts/copy-vendor.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json",
    "synth": "cdk synth",
    "diff": "cdk diff"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-ssm": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@fastify/compress": "^9.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/view": "^10.0.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "eta": "^3.5.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "htmx.org": "^2.0.4",
    "lit": "^3.2.1",
    "lucide-static": "^1.18.0",
    "undici": "^8.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "aws-cdk": "^2.1000.2",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
