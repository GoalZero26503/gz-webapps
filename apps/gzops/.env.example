# Local development environment. Copy to .env and fill in. In AWS, all of
# this comes from CDK-set environment variables and SSM parameters.
APP_NAME=gzops
STAGE=dev
APP_BASE_URL=http://localhost:3000

# Local Postgres (e.g. `docker run -e POSTGRES_HOST_AUTH_METHOD=trust -p 5432:5432 postgres:16`)
DATABASE_URL=postgres://postgres@localhost:5432/postgres

# Secrets — local values only; AWS stages read these from SSM at
# /gzweb/gzops/{stage}/{jwt_secret,google_client_id,google_client_secret}
JWT_SECRET=local-dev-secret-not-for-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# First login bootstrap: this email becomes admin on first sign-in
SEED_ADMIN_EMAIL=you@bioliteenergy.com
