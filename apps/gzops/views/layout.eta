<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= it.title ? `${it.title} — ` : '' %>GZOps</title>
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="stylesheet" href="/vendor/lucide/lucide.css" />
  <script src="/vendor/htmx.min.js" defer></script>
  <script type="module" src="/assets/app.js"></script>
</head>
<body>
  <% if (it.user && it.area) { %>
  <input type="checkbox" id="navToggle" class="nav-toggle-cb" hidden />
  <header class="topnav">
    <label for="navToggle" class="nav-burger" aria-label="Open navigation"><i class="icon-menu"></i></label>
    <a class="brand" href="/">gzops<span class="cursor">_</span></a>
    <% if (it.stage !== 'prod') { %><span class="badge badge-stage"><%= it.stage %></span><% } %>
    <nav class="area-tabs">
      <% it.areaTabs.forEach(function (t) { %>
        <a class="tab <%= t.key === it.area ? 'active' : '' %>" href="<%= t.href %>"><%= t.label %></a>
      <% }) %>
    </nav>
    <span class="grow"></span>
    <details class="bell">
      <summary class="bell-btn" title="Notifications">
        <i class="icon-bell"></i>
        <% if (it.unread > 0) { %><span class="bell-count"><%= it.unread %></span><% } %>
      </summary>
      <div class="bell-menu">
        <div class="bm-head">
          <b>Notifications</b><span class="grow"></span>
          <% if (it.unread > 0) { %>
            <form method="post" action="/notifications/read"><button class="btn sm ghost" type="submit">Mark all read</button></form>
          <% } %>
        </div>
        <div class="bm-list">
          <% if (it.notifs.length === 0) { %>
            <div class="notif"><div class="n-t muted">No notifications</div></div>
          <% } %>
          <% it.notifs.slice(0, 12).forEach(function (n) { %>
            <a class="notif <%= n.read ? '' : 'unread' %>" href="<%= n.href || '#' %>">
              <div class="n-t"><%= n.text %></div>
              <div class="n-at"><%~ it.timeAgo(n.at) %></div>
            </a>
          <% }) %>
        </div>
      </div>
    </details>
    <details class="user-menu">
      <summary class="user-btn" title="Account"><i class="icon-circle-user"></i></summary>
      <div class="user-drop">
        <div class="ud-id">
          <div class="ud-name"><%= it.user.name || it.user.email %></div>
          <div class="ud-email"><%= it.user.email %></div>
          <span class="ud-role"><%= it.user.role %></span>
        </div>
        <form method="post" action="/auth/logout"><button class="btn btn-ghost sm block" type="submit"><i class="icon-log-out"></i> Sign out</button></form>
      </div>
    </details>
  </header>
  <div class="shell">
    <label for="navToggle" class="nav-scrim"></label>
    <aside class="sidebar">
      <nav class="drawer-areas">
        <% it.areaTabs.forEach(function (t) { %>
          <a class="darea <%= t.key === it.area ? 'active' : '' %>" href="<%= t.href %>"><%= t.label %></a>
        <% }) %>
      </nav>
      <% it.sidebar.forEach(function (group) { %>
        <% if (group.heading) { %><div class="nav-section"><%= group.heading %></div><% } %>
        <% group.items.forEach(function (item) { %>
          <a class="nav-item <%= item.key === it.active ? 'active' : '' %>" href="<%= item.href %>">
            <i class="ico <%= item.icon %>"></i>
            <span><%= item.label %></span>
            <% if (item.health) { %><span class="grow"></span><span class="dot <%= item.health %>"></span><% } %>
          </a>
        <% }) %>
      <% }) %>
      <div class="spacer"></div>
      <div class="foot">gzops · <%= it.stage %></div>
    </aside>
    <main class="main">
      <div class="content">
        <%~ it.body %>
      </div>
    </main>
  </div>
  <% } else { %>
  <main class="gate">
    <%~ it.body %>
  </main>
  <% } %>
</body>
</html>
