<% layout('layout') %>
<div class="gate-card">
  <div class="logo">GZ<span class="cursor">Ops</span></div>
  <h1>Release operations portal</h1>
  <p>Sign in with your company Google account to continue.</p>
  <% if (it.error) { %>
  <div class="callout callout-error"><%= it.error %></div>
  <% } %>
  <a class="btn btn-primary block" href="/auth/login?return_to=<%= encodeURIComponent(it.returnTo) %>">
    <i class="icon-log-in"></i> Sign in with Google
  </a>
</div>
